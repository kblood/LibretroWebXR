+/* Single rwebinput instance, captured at init so the exported per-port
+ * light-gun setter (driven from JS) can reach the live input state. */
+static rwebinput_input_t *g_rwebinput = NULL;
+
+/* Exported to JS (see EXPORTED_FUNCTIONS in Makefile.emscripten). The frontend
+ * calls Module._rwebinput_set_lightgun(port, x, y, buttons) each frame to drive
+ * gun `port` (0-based) independently of the DOM mouse. x/y are canvas-relative
+ * pixels in the same coordinate space as the mouse handler (targetX*dpr); they
+ * are run through the same viewport translation as the single-gun path. buttons
+ * is a bitmask matching mouse.buttons (bit RWEBINPUT_MOUSE_BTNL = trigger,
+ * BTNR = reload/aux, BTNM = start/aux_b). A negative port, or a port >=
+ * RWEBINPUT_MAX_LIGHTGUN, is ignored. To stop driving a port and fall back to
+ * the shared mouse, call rwebinput_clear_lightgun(port). */
+void rwebinput_set_lightgun(int port, int x, int y, int buttons)
+{
+   if (!g_rwebinput || port < 0 || port >= RWEBINPUT_MAX_LIGHTGUN)
+      return;
+   g_rwebinput->lightgun[port].x       = x;
+   g_rwebinput->lightgun[port].y       = y;
+   g_rwebinput->lightgun[port].buttons = (uint8_t)buttons;
+   g_rwebinput->lightgun[port].active  = true;
+}
+
+/* Exported to JS: revert `port` to the shared-mouse light-gun path. */
+void rwebinput_clear_lightgun(int port)
+{
+   if (!g_rwebinput || port < 0 || port >= RWEBINPUT_MAX_LIGHTGUN)
+      return;
+   g_rwebinput->lightgun[port].active  = false;
+   g_rwebinput->lightgun[port].buttons = 0;
+}
