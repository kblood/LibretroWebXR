+/* --- Multi-port light-gun support (added for WebXR 2-gun co-op) ----------
+ * rwebinput has a single DOM mouse, so the base RETRO_DEVICE_LIGHTGUN case
+ * feeds the SAME pointer to every port that queries a light gun: two guns on
+ * one console (2-player Duck Hunt) share one aim point. To drive each gun
+ * independently the frontend writes PER-PORT pointer state through the
+ * exported setter rwebinput_set_lightgun() (callable from JS as
+ * Module._rwebinput_set_lightgun). A port that has been set "active" reads its
+ * own x/y/buttons; ports never set fall back to the shared mouse, so the
+ * existing single-gun path is unchanged. */
+#define RWEBINPUT_MAX_LIGHTGUN 8
+
+typedef struct rwebinput_lightgun_state
+{
+   int     x;        /* canvas-relative pixel coords, same space as mouse.x/.y */
+   int     y;
+   uint8_t buttons;  /* bitmask, same bit layout as mouse.buttons             */
+   bool    active;   /* true once the frontend has set this port at least once */
+} rwebinput_lightgun_state_t;
