# Cross-origin isolation — required so window.crossOriginIsolated === true,
# which is the gate Quest / Chrome / Firefox put around SharedArrayBuffer.
# The threaded libretro/JIT core imports shared Wasm memory backed by
# SharedArrayBuffer; without these headers it will not initialize.
<IfModule mod_headers.c>
  Header set Cross-Origin-Embedder-Policy "require-corp"
  Header set Cross-Origin-Opener-Policy   "same-origin"
  # Allow the Lightrec/Play! WebAssembly backend to compile generated blocks.
  # JS eval remains disabled: wasm-unsafe-eval is deliberately narrower.
  Header set Content-Security-Policy "script-src 'self' 'wasm-unsafe-eval'; worker-src 'self' blob:"

  # Cache discipline borrowed from castlemastervr — Quest browser is happy
  # to serve stale modules unless told otherwise.
  <FilesMatch "\.(js|mjs|html|json)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# Apache 2.4 default mime.types covers .js but not always .wasm.
<IfModule mod_mime.c>
  AddType application/wasm .wasm
</IfModule>
